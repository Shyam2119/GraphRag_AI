# GraphRAG for Time-Series Reddit Intelligence
# Copy this file to .env only if you want to override the built-in safe defaults.
# A clean clone can run `python demo.py` without creating .env.

# -----------------------------------------------------------------------------
# Safe reviewer defaults
# -----------------------------------------------------------------------------
USE_SAMPLE_DATA=true
USE_FALLBACK_GRAPH=true
USE_CHROMA=false
SCRAPE_METHOD=auto
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=auto
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional LLM providers
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Optional live Reddit API path
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=GraphRAG/1.0 (by YourUsername)

# -----------------------------------------------------------------------------
# Optional live web-scraping path (no Reddit API credentials required)
# Set USE_SAMPLE_DATA=false and SCRAPE_METHOD=web to use this path.
# Supported backends:
#   ddgs | duckduckgo | crawl4ai | firecrawl | brave | tavily | trivial
# -----------------------------------------------------------------------------
WEB_SCRAPER_BACKEND=ddgs
WEB_SCRAPER_FALLBACK_BACKENDS=firecrawl,trivial,brave,duckduckgo
BRAVE_SEARCH_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

SCRAPE_DELAY=1.5
SCRAPE_CONCURRENCY=4
SCRAPE_TIMEOUT=10
REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA,artificial,openai,Futurology
REDDIT_SEARCH_QUERY=RAG OR "retrieval augmented" OR "AI safety" OR "open source LLM"
REDDIT_POST_LIMIT=50
REDDIT_COMMENT_LIMIT=20

# -----------------------------------------------------------------------------
# Optional persistent stores
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123
CHROMA_PERSIST_DIR=./data/chroma

# -----------------------------------------------------------------------------
# Optional custom time windows
# -----------------------------------------------------------------------------
WINDOW_1_START=2025-07-01
WINDOW_1_END=2025-09-30
WINDOW_2_START=2025-10-01
WINDOW_2_END=2025-12-31
WINDOW_3_START=2026-01-01
WINDOW_3_END=2026-03-31
